# Supabase connection — copy this file to .env.local and fill in real values.
# Find these in your Supabase project: Settings → API.
# The anon key is safe to expose in the browser; RLS is what protects data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic — used by the chat Supabase Edge Function (server-side only, never in the browser).
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase Personal Access Token — only needed once to deploy the chat edge function.
# Generate one at supabase.com/dashboard/account/tokens (starts with sbp_)
SUPABASE_ACCESS_TOKEN=sbp_...
